APP_NAME="User Centralized Management"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com/user-centralized-managment

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database ────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ucm_db
DB_USERNAME=ucm_user
DB_PASSWORD=

# ── Session / Cache / Queue ─────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# ── Mail ────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=your-smtp-server.com
MAIL_PORT=25
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="ucm@your-domain.com"
MAIL_FROM_NAME="${APP_NAME} Autosystem"

# ── LDAP / Active Directory ─────────────────────────────────────────────────
# LDAP_HOST      : FQDN หรือ IP ของ Domain Controller (เช่น EXAMPLE.COM หรือ 192.168.1.10)
# LDAP_PORT      : 389 (plain) หรือ 636 (LDAPS)
# LDAP_BASE_DN   : OU ที่เก็บ user accounts
# LDAP_BIND_DN   : Service account สำหรับ bind
# LDAP_BIND_PASSWORD : Password ของ service account
LDAP_HOST=EXAMPLE.COM
LDAP_PORT=389
LDAP_BASE_DN="OU=Users,DC=EXAMPLE,DC=COM"
LDAP_BIND_DN="EXAMPLE\\serviceaccount"
LDAP_BIND_PASSWORD=
LDAP_USER_FILTER=(sAMAccountName={username})
LDAP_USERNAME_ATTRIBUTE=sAMAccountName

# ── UCM Application Settings ────────────────────────────────────────────────
# UCM_ALLOWED_DEPARTMENT : ชื่อแผนกใน AD ที่อนุญาตให้ login ได้ (เว้นว่าง = ทุกแผนก)
# UCM_AUDIT_DEPARTMENTS  : แผนกที่ได้รับ read-only access (คั่นด้วย comma)
UCM_ALLOWED_DEPARTMENT=""
UCM_AUDIT_DEPARTMENTS=""

# ── Anthropic / Claude AI (AI Schema Analysis ใน Connector Wizard) ──────────
# ไม่จำเป็น — ถ้าไม่ตั้งค่า ระบบ fallback ไป Rule-based suggester อัตโนมัติ
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-6

VITE_APP_NAME="${APP_NAME}"
